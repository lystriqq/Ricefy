/* Generated by Ricefy — {{ config.name }} */
{#- ─── Derived values ─────────────────────────────────────────────────────── -#}
{%- set _pos_str = {"left": "west", "center": "center", "right": "east"} -%}
{%- set _pos_num = {"left": 7, "center": 0, "right": 3} -%}
{%- set _modi    = {"launcher": "drun,run", "dmenu": "dmenu", "drun": "drun", "window": "window"} -%}
{%- set radius   = [config.wm.rounding // 2, 8] | min -%}
{%- set icon_size = (config.font.size * 2) -%}
{%- set loc_str  = _pos_str[config.launcher.position] -%}
{%- set loc_num  = _pos_num[config.launcher.position] -%}
{%- set modi_str = _modi[config.launcher.mode] -%}

/* ─── Configuration ──────────────────────────────────────────────────────── */

configuration {
    modi:                "{{ modi_str }}";
    font:                "{{ config.font.mono_family }} {{ config.font.size }}";
    show-icons:          {{ config.launcher.show_icons | lower }};
    drun-display-format: "{name}";
    location:            {{ loc_num }};
    disable-history:     false;
    hide-scrollbar:      true;
    sidebar-mode:        false;
}

/* ─── Global variables ───────────────────────────────────────────────────── */

* {
    background-color:    {{ config.colors.background }};
    surface-color:       {{ config.colors.surface }};
    foreground:          {{ config.colors.foreground }};
    text-color:          {{ config.colors.foreground }};
    border-color:        {{ config.colors.border }};
    accent-color:        {{ config.colors.accent }};
    urgent-color:        #cc241d;
    radius:              {{ radius }}px;
}

/* ─── Window ─────────────────────────────────────────────────────────────── */

window {
    width:               {{ config.launcher.width }}px;
    border-radius:       @radius;
    border:              1px;
    border-color:        @border-color;
    background-color:    @background-color;
    padding:             8px;
    location:            {{ loc_str }};
    anchor:              {{ loc_str }};
    x-offset:            {% if config.launcher.position == "left" %}24px{% elif config.launcher.position == "right" %}-24px{% else %}0px{% endif %};
}

/* ─── Mainbox ────────────────────────────────────────────────────────────── */

mainbox {
    background-color:    transparent;
    spacing:             8px;
    padding:             0px;
    children:            [inputbar, listview];
}

/* ─── Inputbar ───────────────────────────────────────────────────────────── */

inputbar {
    background-color:    @surface-color;
    text-color:          @foreground;
    border:              0;
    border-radius:       @radius;
    padding:             8px 12px;
    spacing:             8px;
    children:            [entry, prompt];
}

prompt {
    background-color:    transparent;
    text-color:          @accent-color;
    padding:             0px;
    expand:              false;
}

entry {
    background-color:    transparent;
    text-color:          @foreground;
    placeholder:         "Search...";
    placeholder-color:   @border-color;
}

/* ─── Listview ───────────────────────────────────────────────────────────── */

listview {
    background-color:    transparent;
    lines:               {{ config.launcher.lines }};
    spacing:             4px;
    scrollbar:           false;
    padding:             4px 0px;
}

/* ─── Elements ───────────────────────────────────────────────────────────── */

element {
    background-color:    transparent;
    text-color:          @foreground;
    padding:             8px 12px;
    border-radius:       @radius;
    spacing:             8px;
    orientation:         horizontal;
    min-height:          28px;
}

element normal.normal {
    background-color:    transparent;
    text-color:          @foreground;
}

element normal.urgent {
    background-color:    @urgent-color;
    text-color:          @background-color;
}

element alternate.normal {
    background-color:    transparent;
    text-color:          @foreground;
}

element selected.normal {
    background-color:    @accent-color;
    text-color:          @background-color;
    border-radius:       @radius;
}

element selected.urgent {
    background-color:    @urgent-color;
    text-color:          @background-color;
}

element-icon {
    background-color:    transparent;
    size:                {{ icon_size }}px;
}

element-text {
    background-color:    transparent;
    text-color:          inherit;
    vertical-align:      0.5;
}

/* ─── Scrollbar ──────────────────────────────────────────────────────────── */

scrollbar {
    background-color:    @surface-color;
    handle-color:        @accent-color;
    handle-width:        4px;
    border-radius:       2px;
}
