#!/usr/bin/env bash
# Generated by Ricefy — {{ config.name }}
# https://ricefy.org
#
# Run with: bash install.sh
{#- ─── Font → Arch package mapping ─────────────────────────────────────── -#}
{%- set _font_pkg = {
    "JetBrains Mono":    "ttf-jetbrains-mono-nerd",
    "Fira Code":         "ttf-firacode-nerd",
    "Cascadia Code":     "ttf-cascadia-code-nerd",
    "Hack Nerd Font":    "ttf-hack-nerd",
    "Iosevka Nerd Font": "ttf-iosevka-nerd",
    "Source Code Pro":   "ttf-sourcecodepro-nerd",
    "Inconsolata":       "ttf-inconsolata-nerd",
    "IBM Plex Mono":     "ttf-ibmplex-mono-nerd",
    "Geist Sans":        "ttf-geist",
    "Inter":             "ttf-inter",
    "IBM Plex Sans":     "ttf-ibm-plex",
    "Noto Sans":         "noto-fonts",
    "Roboto":            "ttf-roboto",
    "Ubuntu":            "ttf-ubuntu-font-family",
    "Cantarell":         "cantarell-fonts",
} -%}
{#- ─── Pacman / AUR split ───────────────────────────────────────────────── -#}
{#- Launcher -#}
{%- if config.launcher.kind == "rofi" -%}
  {%- set _launcher_pacman = ["rofi-wayland"] -%}
  {%- set _launcher_aur    = [] -%}
{%- else -%}
  {%- set _launcher_pacman = ["wofi"] -%}
  {%- set _launcher_aur    = [] -%}
{%- endif -%}
{#- Lockscreen (session lock — SDDM is always installed separately as display manager) -#}
{%- if config.lockscreen.kind == "hyprlock" -%}
  {%- set _lock_pacman = [] -%}
  {%- set _lock_aur    = ["hyprlock"] -%}
{%- elif config.lockscreen.kind == "swaylock" -%}
  {%- set _lock_pacman = ["swaylock"] -%}
  {%- set _lock_aur    = ["swaylock-effects-git"] -%}
{%- else -%}
  {%- set _lock_pacman = [] -%}
  {%- set _lock_aur    = [] -%}
{%- endif -%}
{#- Wallpaper tool -#}
{%- if config.wm.wallpaper_tool == "swaybg" -%}
  {%- set _wall_pacman = ["swaybg"] -%}
  {%- set _wall_aur    = [] -%}
{%- elif config.wm.wallpaper_tool == "hyprpaper" -%}
  {%- set _wall_pacman = ["hyprpaper"] -%}
  {%- set _wall_aur    = [] -%}
{%- else -%}
  {%- set _wall_pacman = [] -%}
  {%- set _wall_aur    = ["swww"] -%}
{%- endif -%}
{#- Fonts (unique set across heading, body, mono) -#}
{%- set _used_fonts = [config.font.mono_family, config.font.heading_family, config.font.body_family] | unique | list -%}
{%- set _aur_fonts  = [] -%}
{%- for f in _used_fonts -%}
  {%- if _font_pkg[f] is defined -%}
    {%- if _aur_fonts.append(_font_pkg[f]) -%}{%- endif -%}
  {%- endif -%}
{%- endfor -%}
{%- set _all_aur = (_lock_aur + _wall_aur + _aur_fonts + ["wlogout"]) | unique | list -%}

set -euo pipefail

# ─── Colours ─────────────────────────────────────────────────────────────────

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'

info()    { echo -e "${BLUE}[INFO]${NC}  $*"; }
ok()      { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
die()     { echo -e "${RED}[ERROR]${NC} $*"; exit 1; }

# ─── OS check ────────────────────────────────────────────────────────────────

[[ -f /etc/arch-release ]] || die "This script requires Arch Linux."
ok "Arch Linux detected."

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ─── Pacman packages ─────────────────────────────────────────────────────────

PACMAN_PKGS=(
    # Compositor + bar
    hyprland
    waybar
    xdg-desktop-portal-hyprland
    xdg-user-dirs
    # Terminal
    kitty
    # Notification daemon
    dunst
    libnotify
    # Display manager (always)
    sddm
    # Launcher
    {{ (_launcher_pacman) | join(' ') }}
    # Session lockscreen
{%- for p in _lock_pacman %}
    {{ p }}
{%- endfor %}
    # Wallpaper
{%- for p in _wall_pacman %}
    {{ p }}
{%- endfor %}
    # Audio
    pipewire
    pipewire-alsa
    pipewire-pulse
    wireplumber
    pavucontrol
    # Network / Bluetooth
    networkmanager
    network-manager-applet
    blueman
    # System
    brightnessctl
    polkit-gnome
    grim
    slurp
    wl-clipboard
    # File manager
    thunar
    thunar-archive-plugin
)

info "Installing pacman packages…"
sudo pacman -Syu --needed --noconfirm "${PACMAN_PKGS[@]}"
ok "Pacman packages installed."

# ─── AUR packages (via yay) ──────────────────────────────────────────────────

AUR_PKGS=(
{%- for p in _all_aur %}
    {{ p }}
{%- endfor %}
)

if command -v yay &>/dev/null; then
    info "Installing AUR packages via yay…"
    yay -S --needed --noconfirm "${AUR_PKGS[@]}"
    ok "AUR packages installed."
elif command -v paru &>/dev/null; then
    info "Installing AUR packages via paru…"
    paru -S --needed --noconfirm "${AUR_PKGS[@]}"
    ok "AUR packages installed."
else
    warn "No AUR helper found (yay/paru). Skipping AUR packages:"
    for p in "${AUR_PKGS[@]}"; do warn "  - $p"; done
    warn "Install them manually before using this rice."
fi

# ─── Backup existing configs ─────────────────────────────────────────────────

TS="$(date +%Y%m%d_%H%M%S)"

backup() {
    local src="$1"
    if [[ -e "$src" ]]; then
        mv "$src" "${src}.bak_${TS}"
        warn "Backed up $src → ${src}.bak_${TS}"
    fi
}

info "Backing up existing configs…"
backup "$HOME/.config/hypr"
backup "$HOME/.config/waybar"
backup "$HOME/.config/kitty"
backup "$HOME/.config/{{ config.launcher.kind }}"
{% if config.lockscreen.kind == "swaylock" %}
backup "$HOME/.config/swaylock"
{% endif %}

# ─── Create config directories ───────────────────────────────────────────────

info "Creating config directories…"
mkdir -p \
    "$HOME/.config/hypr" \
    "$HOME/.config/waybar" \
    "$HOME/.config/kitty" \
    "$HOME/.config/{{ config.launcher.kind }}"
{% if config.lockscreen.kind == "swaylock" %}
mkdir -p "$HOME/.config/swaylock"
{% endif %}

# ─── Copy config files ───────────────────────────────────────────────────────

info "Copying config files…"

# Hyprland
cp "$SCRIPT_DIR/hyprland/hyprland.lua"  "$HOME/.config/hypr/hyprland.lua"
ok "Hyprland config → ~/.config/hypr/hyprland.lua"

# Waybar
cp "$SCRIPT_DIR/waybar/config"          "$HOME/.config/waybar/config"
cp "$SCRIPT_DIR/waybar/style.css"       "$HOME/.config/waybar/style.css"
ok "Waybar config → ~/.config/waybar/"

# Kitty
cp "$SCRIPT_DIR/kitty/kitty.conf"       "$HOME/.config/kitty/kitty.conf"
ok "Kitty config → ~/.config/kitty/kitty.conf"

# Launcher ({{ config.launcher.kind }})
{% if config.launcher.kind == "rofi" %}
cp "$SCRIPT_DIR/rofi/config.rasi"       "$HOME/.config/rofi/config.rasi"
ok "Rofi config → ~/.config/rofi/config.rasi"
{% else %}
cp "$SCRIPT_DIR/wofi/config"            "$HOME/.config/wofi/config"
cp "$SCRIPT_DIR/wofi/style.css"         "$HOME/.config/wofi/style.css"
ok "Wofi config → ~/.config/wofi/"
{% endif %}

# Session lockscreen ({{ config.lockscreen.kind }})
{% if config.lockscreen.kind == "hyprlock" %}
cp "$SCRIPT_DIR/hyprlock/hyprlock.conf" "$HOME/.config/hypr/hyprlock.conf"
ok "Hyprlock config → ~/.config/hypr/hyprlock.conf"
{% elif config.lockscreen.kind == "swaylock" %}
cp "$SCRIPT_DIR/swaylock/swaylock.conf" "$HOME/.config/swaylock/config"
ok "Swaylock config → ~/.config/swaylock/config"
{% endif %}

# SDDM login theme (always — display manager login screen)
SDDM_THEME_DIR="/usr/share/sddm/themes/ricefy-{{ config.name | lower | replace(' ', '-') }}"
sudo mkdir -p "$SDDM_THEME_DIR"
sudo cp "$SCRIPT_DIR/sddm/theme.conf"   "$SDDM_THEME_DIR/theme.conf"
sudo cp "$SCRIPT_DIR/sddm/Main.qml"     "$SDDM_THEME_DIR/Main.qml"
sudo mkdir -p /etc/sddm.conf.d
sudo tee /etc/sddm.conf.d/ricefy.conf > /dev/null <<EOF
[Theme]
Current=ricefy-{{ config.name | lower | replace(' ', '-') }}
EOF
ok "SDDM login theme → $SDDM_THEME_DIR"

{% if config.wm.wallpaper_image %}
# Wallpaper
WALLPAPER_DEST="$HOME/.config/hypr/wallpaper.{{ config.wm.wallpaper_image.split('.')[-1] }}"
cp "$SCRIPT_DIR/wallpaper"              "$WALLPAPER_DEST"
ok "Wallpaper → $WALLPAPER_DEST"
{% endif %}

# ─── Services ────────────────────────────────────────────────────────────────

info "Enabling system services…"
sudo systemctl enable --now NetworkManager
ok "NetworkManager enabled."

sudo systemctl enable sddm
ok "SDDM enabled (will start on next boot)."

# ─── Done ────────────────────────────────────────────────────────────────────

echo ""
echo -e "${BOLD}${GREEN}╔══════════════════════════════════════╗${NC}"
echo -e "${BOLD}${GREEN}║   {{ config.name | center(36) }}   ║${NC}"
echo -e "${BOLD}${GREEN}║   Rice installed successfully!       ║${NC}"
echo -e "${BOLD}${GREEN}╚══════════════════════════════════════╝${NC}"
echo ""
echo -e "  ${BOLD}Next steps:${NC}"
echo -e "  1. Reboot: ${YELLOW}sudo reboot${NC}"
echo -e "  2. Reload Waybar: ${YELLOW}Super + Shift + R${NC} (if already running)"
echo -e "  3. Open terminal: ${YELLOW}Super + T${NC}"
echo -e "  4. Open launcher: ${YELLOW}Super + R${NC}"
echo ""
echo -e "  Generated by ${BLUE}https://ricefy.org${NC}"
