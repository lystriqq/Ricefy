{#- Generated by Ricefy — {{ config.name }} -#}
{#- ─── Macro : format string selon show_icons / show_labels ─────────────── -#}
{%- macro fmt(icon, label) -%}
{%- if config.bar.show_icons and config.bar.show_labels -%}{{ icon }}  {{ label }}
{%- elif config.bar.show_icons -%}{{ icon }}
{%- else -%}{{ label }}
{%- endif -%}
{%- endmacro -%}
{
    "layer": "top",
    "position": "{{ config.bar.position }}",
    "height": {{ config.bar.height }},
    "spacing": {{ config.bar.spacing }},

    "modules-left":   {{ config.bar.modules_left | tojson }},
    "modules-center": {{ config.bar.modules_center | tojson }},
    "modules-right":  {{ config.bar.modules_right | tojson }},

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "on-scroll-up":   "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "persistent-workspaces": {
            "1": [], "2": [], "3": [], "4": [], "5": []
        }
    },

    "hyprland/window": {
        "format": "{{ fmt('▣', '{}') }}",
        "max-length": 50,
        "separate-outputs": true
    },

    "hyprland/taskbar": {
        "format": "{icon}",
        "icon-size": {{ (config.bar.height * 0.6) | int }},
        "tooltip": true,
        "on-click": "activate",
        "on-right-click": "fullscreen"
    },

    "hyprland/submap": {
        "format": "{{ fmt('◈', '{}') }}",
        "max-length": 20,
        "always-in-output": false
    },

    "clock": {
        "format": "{{ fmt('◷', '{:%H:%M}') }}",
        "format-alt": "{{ fmt('◷', '{:%A %d %B}') }}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 60
    },

    "custom/date": {
        "format": "{{ fmt('◻', '{}') }}",
        "interval": 3600,
        "exec": "date '+%a %d %b'"
    },

    "custom/separator": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    },

    "cpu": {
        "format": "{{ fmt('▤', '{usage}%') }}",
        "tooltip": true,
        "interval": 5
    },

    "memory": {
        "format": "{{ fmt('▥', '{used:0.1f}G') }}",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G",
        "interval": 10
    },

    "disk": {
        "format": "{{ fmt('▦', '{percentage_used}%') }}",
        "tooltip-format": "{path}: {used} / {total}",
        "interval": 30,
        "path": "/"
    },

    "temperature": {
        "format": "{{ fmt('◉', '{temperatureC}°C') }}",
        "format-critical": "{{ fmt('◉', '{temperatureC}°C !') }}",
        "critical-threshold": 80,
        "interval": 10
    },

    "network": {
        "format-wifi":        "{{ fmt('~', '{essid}') }}",
        "format-ethernet":    "{{ fmt('=', '{ifname}') }}",
        "format-disconnected":"{{ fmt('=', 'off') }}",
        "tooltip-format-wifi":    "{essid} ({signalStrength}%) ↑{bandwidthUpBytes} ↓{bandwidthDownBytes}",
        "tooltip-format-ethernet":"{ifname}: {ipaddr}",
        "on-click": "nm-connection-editor",
        "interval": 10
    },

    "bluetooth": {
        "format":                   "{{ fmt('◎', '{status}') }}",
        "format-connected":         "{{ fmt('◎', '{device_alias}') }}",
        "format-connected-battery": "{{ fmt('◎', '{device_alias} {device_battery_percentage}%') }}",
        "format-disabled":          "{{ fmt('◎', 'Off') }}",
        "tooltip-format":           "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\n{device_enumerate}",
        "on-click": "blueman-manager"
    },

    "battery": {
        "states": { "good": 95, "warning": 30, "critical": 15 },
        "format":          "{{ fmt('{icon}', '{capacity}%') }}",
        "format-charging": "{{ fmt('▲', '{capacity}%') }}",
        "format-plugged":  "{{ fmt('▲', '{capacity}%') }}",
        "format-alt":      "{{ fmt('{icon}', '{time}') }}",
        "format-icons":    ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"],
        "tooltip-format":  "{timeTo}, {capacity}%",
        "interval": 30
    },

    "pulseaudio": {
        "format":       "{{ fmt(')', '{volume}%') }}",
        "format-muted": "{{ fmt(')', 'mute') }}",
        "format-icons": {
            "headphone":  ")",
            "hands-free": ")",
            "headset":    ")",
            "default":    [")", ")", ")"]
        },
        "on-click":   "pavucontrol",
        "scroll-step": 5,
        "tooltip-format": "{desc} — {volume}%"
    },

    "tray": {
        "icon-size": {{ (config.bar.height * 0.5) | int }},
        "spacing":   {{ config.bar.spacing }}
    },

    "custom/power": {
        "format": "⏻",
        "on-click": "wlogout",
        "tooltip": false
    }
}
