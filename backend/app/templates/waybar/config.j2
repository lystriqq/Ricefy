{#- Generated by Ricefy вЂ” {{ config.name }} -#}
{#- в”Ђв”Ђв”Ђ Macro : format string selon show_icons / show_labels в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ -#}
{%- macro fmt(icon, label) -%}
{%- if config.bar.show_icons and config.bar.show_labels -%}{{ icon }}  {{ label }}
{%- elif config.bar.show_icons -%}{{ icon }}
{%- else -%}{{ label }}
{%- endif -%}
{%- endmacro -%}
{
    "layer": "top",
    "position": "{{ config.bar.position }}",
    "height": {{ config.bar.height }},
    "spacing": {{ config.bar.spacing }},

    "modules-left":   {{ config.bar.modules_left | tojson }},
    "modules-center": {{ config.bar.modules_center | tojson }},
    "modules-right":  {{ config.bar.modules_right | tojson }},

    "hyprland/workspaces": {
        "format": "{{ fmt('{icon}', '{name}') }}",
        "on-click": "activate",
        "on-scroll-up":   "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "format-icons": {
            "1": "у°ІЎ", "2": "у°ІЈ", "3": "у°ІҐ", "4": "у°І§", "5": "у°І©",
            "6": "у°І«", "7": "у°І­", "8": "у°ІЇ", "9": "у°І±",
            "urgent":  "у°—–",
            "active":  "у°®Ї",
            "default": "у°Љ "
        }
    },

    "hyprland/window": {
        "format": "{{ fmt('в–Ј', '{}') }}",
        "max-length": 50,
        "separate-outputs": true
    },

    "hyprland/taskbar": {
        "format": "{icon}",
        "icon-size": {{ (config.bar.height * 0.6) | int }},
        "tooltip": true,
        "on-click": "activate",
        "on-right-click": "fullscreen"
    },

    "hyprland/submap": {
        "format": "{{ fmt('в—€', '{}') }}",
        "max-length": 20,
        "always-in-output": false
    },

    "clock": {
        "format": "{{ fmt('в—·', '{:%H:%M}') }}",
        "format-alt": "{{ fmt('в—·', '{:%A %d %B}') }}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 60
    },

    "custom/date": {
        "format": "{{ fmt('в—»', '{}') }}",
        "interval": 3600,
        "exec": "date '+%a %d %b'"
    },

    "custom/separator": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    },

    "cpu": {
        "format": "{{ fmt('в–¤', '{usage}%') }}",
        "tooltip": true,
        "interval": 5
    },

    "memory": {
        "format": "{{ fmt('в–Ґ', '{used:0.1f}G') }}",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G",
        "interval": 10
    },

    "disk": {
        "format": "{{ fmt('в–¦', '{percentage_used}%') }}",
        "tooltip-format": "{path}: {used} / {total}",
        "interval": 30,
        "path": "/"
    },

    "temperature": {
        "format": "{{ fmt('в—‰', '{temperatureC}В°C') }}",
        "format-critical": "{{ fmt('в—‰', '{temperatureC}В°C !') }}",
        "critical-threshold": 80,
        "interval": 10
    },

    "network": {
        "format-wifi":        "{{ fmt('в‡†', '{essid}') }}",
        "format-ethernet":    "{{ fmt('в‡†', '{ifname}') }}",
        "format-disconnected":"{{ fmt('в‡†', 'Off') }}",
        "tooltip-format-wifi":    "{essid} ({signalStrength}%) в†‘{bandwidthUpBytes} в†“{bandwidthDownBytes}",
        "tooltip-format-ethernet":"{ifname}: {ipaddr}",
        "on-click": "nm-connection-editor",
        "interval": 10
    },

    "bluetooth": {
        "format":                   "{{ fmt('в—Ћ', '{status}') }}",
        "format-connected":         "{{ fmt('в—Ћ', '{device_alias}') }}",
        "format-connected-battery": "{{ fmt('в—Ћ', '{device_alias} {device_battery_percentage}%') }}",
        "format-disabled":          "{{ fmt('в—Ћ', 'Off') }}",
        "tooltip-format":           "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\n{device_enumerate}",
        "on-click": "blueman-manager"
    },

    "battery": {
        "states": { "good": 95, "warning": 30, "critical": 15 },
        "format":          "{{ fmt('{icon}', '{capacity}%') }}",
        "format-charging": "{{ fmt('в–І', '{capacity}%') }}",
        "format-plugged":  "{{ fmt('в–І', '{capacity}%') }}",
        "format-alt":      "{{ fmt('{icon}', '{time}') }}",
        "format-icons":    ["в–Ѓ", "в–‚", "в–ѓ", "в–„", "в–…", "в–†", "в–‡", "в–€"],
        "tooltip-format":  "{timeTo}, {capacity}%",
        "interval": 30
    },

    "pulseaudio": {
        "format":       "{{ fmt('{icon}', '{volume}%') }}",
        "format-muted": "{{ fmt('в™Є', 'Mute') }}",
        "format-icons": {
            "headphone":  "в™Є",
            "hands-free": "в™Є",
            "headset":    "в™Є",
            "default":    ["в™Є", "в™Є", "в™Є"]
        },
        "on-click":   "pavucontrol",
        "scroll-step": 5,
        "tooltip-format": "{desc} вЂ” {volume}%"
    },

    "tray": {
        "icon-size": {{ (config.bar.height * 0.5) | int }},
        "spacing":   {{ config.bar.spacing }}
    },

    "custom/power": {
        "format": "вЏ»",
        "on-click": "wlogout",
        "tooltip": false
    }
}
