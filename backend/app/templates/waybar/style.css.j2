/* Generated by Ricefy — {{ config.name }} */

/* ─── Palette ────────────────────────────────────────────────────────────── */

:root {
    --background: {{ config.colors.background }};
    --surface:    {{ config.colors.surface }};
    --foreground: {{ config.colors.foreground }};
    --accent:     {{ config.colors.accent }};
    --border:     {{ config.colors.border }};

    --font-family: "{{ config.font.mono_family }}", "Symbols Nerd Font", monospace;
    --font-size:   {{ config.font.size }}px;
    --bar-height:  {{ config.bar.height }}px;
    --spacing:     {{ config.bar.spacing }}px;
    --radius:      {{ [config.wm.rounding // 2, 8] | min }}px;
}

/* ─── Reset ──────────────────────────────────────────────────────────────── */

* {
    border:        none;
    border-radius: 0;
    font-family:   var(--font-family);
    font-size:     var(--font-size);
    min-height:    0;
}

/* ─── Bar ────────────────────────────────────────────────────────────────── */

#waybar {
    background-color: var(--background);
    color:            var(--foreground);
    border-{% if config.bar.position == "top" %}bottom{% else %}top{% endif %}: 1px solid var(--border);
    font-family:      var(--font-family);
}

/* ─── Sections ───────────────────────────────────────────────────────────── */

.modules-left,
.modules-center,
.modules-right {
    padding: 0 var(--spacing);
}

.modules-left   { justify-content: flex-start; }
.modules-center { justify-content: center; }
.modules-right  { justify-content: flex-end; }

/* ─── Module base ────────────────────────────────────────────────────────── */

#clock,
#cpu,
#memory,
#disk,
#temperature,
#network,
#bluetooth,
#battery,
#pulseaudio,
#tray,
#custom-date,
#custom-separator,
#custom-power,
#window,
#submap,
#taskbar {
    background-color: var(--surface);
    color:            var(--foreground);
    padding:          0 12px;
    margin:           {{ (config.bar.height * 0.12) | int }}px 2px;
    border-radius:    var(--radius);
    transition:       background-color 0.2s ease, color 0.2s ease;
}

/* ─── Hover ──────────────────────────────────────────────────────────────── */

#clock:hover,
#cpu:hover,
#memory:hover,
#disk:hover,
#temperature:hover,
#network:hover,
#bluetooth:hover,
#battery:hover,
#pulseaudio:hover,
#custom-date:hover,
#custom-power:hover {
    background-color: var(--accent);
    color:            var(--background);
}

/* ─── Workspaces ─────────────────────────────────────────────────────────── */

#workspaces {
    background-color: var(--surface);
    border-radius:    var(--radius);
    margin:           {{ (config.bar.height * 0.12) | int }}px 2px;
    padding:          0 4px;
}

#workspaces button {
    background-color: transparent;
    color:            var(--foreground);
    padding:          0 8px;
    border-radius:    var(--radius);
    min-width:        20px;
    transition:       background-color 0.15s ease, color 0.15s ease;
}

#workspaces button:hover {
    background-color: var(--border);
    color:            var(--foreground);
}

#workspaces button.active {
    background-color: var(--accent);
    color:            var(--background);
    font-weight:      bold;
}

#workspaces button.urgent {
    background-color: #cc241d;
    color:            #fbf1c7;
}

/* ─── Module states ──────────────────────────────────────────────────────── */

#battery.charging,
#battery.plugged {
    color:            var(--background);
    background-color: var(--accent);
}

#battery.warning:not(.charging) {
    color:            #fabd2f;
    background-color: var(--surface);
    border:           1px solid #fabd2f;
}

#battery.critical:not(.charging) {
    color:            #cc241d;
    background-color: var(--surface);
    border:           1px solid #cc241d;
    animation:        blink 0.5s step-end infinite alternate;
}

#temperature.critical {
    color:            #cc241d;
    background-color: var(--surface);
    border:           1px solid #cc241d;
}

#network.disconnected {
    color: var(--border);
}

#pulseaudio.muted {
    color: var(--border);
}

/* ─── Separator ──────────────────────────────────────────────────────────── */

#custom-separator {
    background-color: transparent;
    color:            var(--border);
    padding:          0 4px;
    margin:           0;
    border-radius:    0;
    font-size:        {{ (config.font.size * 0.8) | int }}px;
}

/* ─── Power button ───────────────────────────────────────────────────────── */

#custom-power {
    background-color: var(--surface);
    color:            var(--foreground);
    padding:          0 14px;
    margin-right:     4px;
    border-radius:    var(--radius);
}

#custom-power:hover {
    background-color: #cc241d;
    color:            #fbf1c7;
}

/* ─── Tray ───────────────────────────────────────────────────────────────── */

#tray {
    background-color: var(--surface);
    border-radius:    var(--radius);
    padding:          0 8px;
}

#tray > .passive  { -gtk-icon-effect: dim; }
#tray > .needs-attention {
    -gtk-icon-effect: highlight;
    background-color: var(--accent);
    border-radius:    var(--radius);
}

/* ─── Animation ──────────────────────────────────────────────────────────── */

@keyframes blink {
    to { background-color: #cc241d; color: #fbf1c7; }
}
