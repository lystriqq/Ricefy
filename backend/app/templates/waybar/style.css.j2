/* Generated by Ricefy — {{ config.name }} */

/* ─── Palette ────────────────────────────────────────────────────────────── */
{%- set _radius = [config.wm.rounding // 2, 8] | min %}
{%- set _margin = (config.bar.height * 0.12) | int %}

@define-color background {{ config.colors.background }};
@define-color surface    {{ config.colors.surface }};
@define-color foreground {{ config.colors.foreground }};
@define-color accent     {{ config.colors.accent }};
@define-color border     {{ config.colors.border }};

/* ─── Reset ──────────────────────────────────────────────────────────────── */

* {
    border:        none;
    border-radius: 0;
    font-family:   "{{ config.font.mono_family }}", "Symbols Nerd Font", monospace;
    font-size:     {{ config.font.size }}px;
    min-height:    0;
}

/* ─── Bar ────────────────────────────────────────────────────────────────── */

#waybar {
    background-color: @background;
    color:            @foreground;
    border-{% if config.bar.position == "top" %}bottom{% else %}top{% endif %}: 1px solid @border;
    font-family:      "{{ config.font.mono_family }}", "Symbols Nerd Font", monospace;
}

/* ─── Sections ───────────────────────────────────────────────────────────── */

.modules-left,
.modules-center,
.modules-right {
    padding: 0 {{ config.bar.spacing }}px;
}

.modules-left   { justify-content: flex-start; }
.modules-center { justify-content: center; }
.modules-right  { justify-content: flex-end; }

/* ─── Module base ────────────────────────────────────────────────────────── */

#clock,
#cpu,
#memory,
#disk,
#temperature,
#network,
#bluetooth,
#battery,
#pulseaudio,
#tray,
#custom-date,
#custom-separator,
#custom-power,
#window,
#submap,
#taskbar {
    background-color: @surface;
    color:            @foreground;
    padding:          0 12px;
    margin:           {{ _margin }}px 2px;
    border-radius:    {{ _radius }}px;
    transition:       background-color 0.2s ease, color 0.2s ease;
}

/* ─── Hover ──────────────────────────────────────────────────────────────── */

#clock:hover,
#cpu:hover,
#memory:hover,
#disk:hover,
#temperature:hover,
#network:hover,
#bluetooth:hover,
#battery:hover,
#pulseaudio:hover,
#custom-date:hover,
#custom-power:hover {
    background-color: @accent;
    color:            @background;
}

/* ─── Workspaces ─────────────────────────────────────────────────────────── */

#workspaces {
    background-color: @surface;
    border-radius:    {{ _radius }}px;
    margin:           {{ _margin }}px 2px;
    padding:          0 4px;
}

#workspaces button {
    background-color: transparent;
    color:            @foreground;
    padding:          0 8px;
    border-radius:    {{ _radius }}px;
    min-width:        20px;
    transition:       background-color 0.15s ease, color 0.15s ease;
}

#workspaces button:hover {
    background-color: @border;
    color:            @foreground;
}

#workspaces button.active {
    background-color: @accent;
    color:            @background;
    font-weight:      bold;
}

#workspaces button.urgent {
    background-color: #cc241d;
    color:            #fbf1c7;
}

/* ─── Module states ──────────────────────────────────────────────────────── */

#battery.charging,
#battery.plugged {
    color:            @background;
    background-color: @accent;
}

#battery.warning:not(.charging) {
    color:            #fabd2f;
    background-color: @surface;
    border:           1px solid #fabd2f;
}

#battery.critical:not(.charging) {
    color:            #cc241d;
    background-color: @surface;
    border:           1px solid #cc241d;
    animation:        blink 0.5s step-end infinite alternate;
}

#temperature.critical {
    color:            #cc241d;
    background-color: @surface;
    border:           1px solid #cc241d;
}

#network.disconnected {
    color: @border;
}

#pulseaudio.muted {
    color: @border;
}

/* ─── Separator ──────────────────────────────────────────────────────────── */

#custom-separator {
    background-color: transparent;
    color:            @border;
    padding:          0 4px;
    margin:           0;
    border-radius:    0;
    font-size:        {{ (config.font.size * 0.8) | int }}px;
}

/* ─── Power button ───────────────────────────────────────────────────────── */

#custom-power {
    background-color: @surface;
    color:            @foreground;
    padding:          0 14px;
    margin-right:     4px;
    border-radius:    {{ _radius }}px;
}

#custom-power:hover {
    background-color: #cc241d;
    color:            #fbf1c7;
}

/* ─── Tray ───────────────────────────────────────────────────────────────── */

#tray {
    background-color: @surface;
    border-radius:    {{ _radius }}px;
    padding:          0 8px;
}

#tray > .passive  { -gtk-icon-effect: dim; }
#tray > .needs-attention {
    -gtk-icon-effect: highlight;
    background-color: @accent;
    border-radius:    {{ _radius }}px;
}

/* ─── Animation ──────────────────────────────────────────────────────────── */

@keyframes blink {
    to { background-color: #cc241d; color: #fbf1c7; }
}
