# Generated by Ricefy — {{ config.name }}
# https://ricefy.org

# ─── Font ────────────────────────────────────────────────────────────────────

font_family      {{ config.terminal.font_family }}
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size        {{ config.terminal.font_size }}.0

# ─── Cursor ──────────────────────────────────────────────────────────────────

cursor_shape     {{ config.terminal.cursor_shape }}
{% if config.terminal.cursor_blink %}
cursor_blink_interval      0.5
cursor_stop_blinking_after 15.0
{% else %}
cursor_blink_interval      0
{% endif %}

# ─── Window ──────────────────────────────────────────────────────────────────

window_padding_width       {{ config.terminal.padding_y }} {{ config.terminal.padding_x }}
hide_window_decorations    yes
confirm_os_window_close    0
background_opacity         1.0
dynamic_background_color   no

# ─── Scrollback ──────────────────────────────────────────────────────────────

scrollback_lines           2000

# ─── Colours ─────────────────────────────────────────────────────────────────

background              {{ config.colors.background }}
foreground              {{ config.colors.foreground }}
selection_background    {{ config.colors.accent }}
selection_foreground    {{ config.colors.background }}
cursor                  {{ config.colors.accent }}
cursor_text_color       {{ config.colors.background }}
url_color               {{ config.colors.accent }}

# 16 ANSI terminal colours (derived from palette accent)
# Normal
color0   {{ term_colors.color0 }}
color1   {{ term_colors.color1 }}
color2   {{ term_colors.color2 }}
color3   {{ term_colors.color3 }}
color4   {{ term_colors.color4 }}
color5   {{ term_colors.color5 }}
color6   {{ term_colors.color6 }}
color7   {{ term_colors.color7 }}

# Bright
color8   {{ term_colors.color8 }}
color9   {{ term_colors.color9 }}
color10  {{ term_colors.color10 }}
color11  {{ term_colors.color11 }}
color12  {{ term_colors.color12 }}
color13  {{ term_colors.color13 }}
color14  {{ term_colors.color14 }}
color15  {{ term_colors.color15 }}

# ─── Misc ────────────────────────────────────────────────────────────────────

enable_audio_bell          no
visual_bell_duration       0.0
window_alert_on_bell       yes
bell_on_tab                no
copy_on_select             clipboard
strip_trailing_spaces      smart
