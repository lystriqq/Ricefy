# Generated by Ricefy — {{ config.name }}
{%- set acc = config.colors.accent[1:]    -%}
{%- set fg  = config.colors.foreground[1:] -%}
{%- set sur = config.colors.surface[1:]   -%}
{%- set bdr = config.colors.border[1:]    -%}
{%- set bg  = config.lockscreen.color[1:] -%}

ignore-empty-password
show-failed-attempts
daemonize

color={{ bg }}ff
{% if config.lockscreen.background_image %}
image={{ config.lockscreen.background_image }}
{% endif %}
{% if config.lockscreen.blur %}
effect-blur=10x5
{% endif %}

font={{ config.font.heading_family }}

ring-color={{ acc }}ff
key-hl-color={{ acc }}ff
bs-hl-color={{ acc }}88
line-color={{ bg }}ff
inside-color={{ sur }}cc
separator-color={{ bdr }}ff

ring-ver-color={{ acc }}aa
line-ver-color={{ bg }}ff
inside-ver-color={{ sur }}cc
text-ver-color={{ fg }}ff

ring-wrong-color=cc241dff
line-wrong-color={{ bg }}ff
inside-wrong-color=281919ff
text-wrong-color=fbf1c7ff

text-color={{ fg }}ff
text-clear-color={{ fg }}ff

indicator-radius=60
indicator-thickness=8
{% if config.lockscreen.clock %}

clock
time-format=%H:%M
date-format=%a %e %b
{% endif %}
