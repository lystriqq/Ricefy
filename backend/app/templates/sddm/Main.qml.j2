{%- set radius = [config.wm.rounding // 2, 12] | min -%}
{%- set h_anchors = {
    "left":   "anchors.left: parent.left\n        anchors.leftMargin: 80",
    "center": "anchors.horizontalCenter: parent.horizontalCenter",
    "right":  "anchors.right: parent.right\n        anchors.rightMargin: 80"
} -%}
{%- set v_anchors = {
    "top":    "anchors.top: parent.top\n        anchors.topMargin: 80",
    "center": "anchors.verticalCenter: parent.verticalCenter",
    "bottom": "anchors.bottom: parent.bottom\n        anchors.bottomMargin: 80"
} -%}
{%- set _font = config.lockscreen.font | default(config.font.mono_family) -%}
// Generated by Ricefy — {{ config.name }}

import QtQuick 2.0
import QtQuick.Controls 2.0
import SddmComponents 2.0

Rectangle {
    id: root

    property int sessionIndex: sessionModel.lastIndex

    TextConstants { id: textConstants }

    Connections {
        target: sddm
        onLoginFailed: {
            errorLabel.text = textConstants.loginFailed
            passwordInput.clear()
            passwordInput.forceActiveFocus()
        }
    }

    // ── Background ────────────────────────────────────────────────────────────

{% if config.lockscreen.background_image %}
    Image {
        anchors.fill: parent
        source: "{{ config.lockscreen.background_image }}"
        fillMode: Image.PreserveAspectCrop
        smooth: true
        asynchronous: true
    }
    Rectangle {
        anchors.fill: parent
        color: "{{ config.lockscreen.background_color }}"
        opacity: 0.4
    }
{% else %}
    color: "{{ config.lockscreen.background_color }}"
{% endif %}

    // ── Content block (positioned by layout config) ───────────────────────────

    Item {
        id: contentBlock
        width: 300
        height: 240

        {{ h_anchors[config.lockscreen.layout] }}
        {{ v_anchors[config.lockscreen.layout_y] }}

        // Clock
        Label {
            id: clockLabel
            anchors.top: parent.top
            anchors.horizontalCenter: parent.horizontalCenter
            text: Qt.formatTime(new Date(), "HH:mm")
            color: "{{ config.colors.foreground }}"
            font.family: "{{ _font }}"
            font.pixelSize: 72
        }

        // Date
        Label {
            id: dateLabel
            anchors.top: clockLabel.bottom
            anchors.topMargin: 4
            anchors.horizontalCenter: parent.horizontalCenter
            text: Qt.formatDate(new Date(), "dddd, MMMM d")
            color: "{{ config.colors.foreground }}"
            font.family: "{{ _font }}"
            font.pixelSize: 13
            opacity: 0.55
        }

{% if config.lockscreen.show_logo | default(false) %}
        // Rice name
        Label {
            id: riceNameLabel
            anchors.top: dateLabel.bottom
            anchors.topMargin: 6
            anchors.horizontalCenter: parent.horizontalCenter
            text: "{{ config.name }}"
            color: "{{ config.colors.accent }}"
            font.family: "{{ _font }}"
            font.pixelSize: 11
            opacity: 0.7
        }
{% endif %}

        // Accent separator
        Rectangle {
            id: accentLine
            anchors.top: dateLabel.bottom
            anchors.topMargin: {{ 32 if (config.lockscreen.show_logo | default(false)) else 20 }}
            anchors.horizontalCenter: parent.horizontalCenter
            width: 40
            height: 2
            color: "{{ config.colors.accent }}"
            opacity: 0.6
        }

        // Username label (dim)
        Label {
            id: userLabel
            anchors.top: accentLine.bottom
            anchors.topMargin: 12
            anchors.horizontalCenter: parent.horizontalCenter
            text: userModel.lastUser
            color: "{{ config.colors.foreground }}"
            font.family: "{{ _font }}"
            font.pixelSize: 12
            opacity: 0.45
        }

        // Password input
        TextField {
            id: passwordInput
            anchors.top: userLabel.bottom
            anchors.topMargin: 8
            anchors.horizontalCenter: parent.horizontalCenter
            width: 200
            echoMode: TextInput.Password
            placeholderText: "password"
            font.family: "{{ _font }}"
            font.pixelSize: 12
            horizontalAlignment: TextInput.AlignHCenter
            Keys.onReturnPressed: sddm.login(userModel.lastUser, passwordInput.text, sessionIndex)
        }

        // Error label
        Label {
            id: errorLabel
            anchors.top: passwordInput.bottom
            anchors.topMargin: 6
            anchors.horizontalCenter: parent.horizontalCenter
            color: "#cc241d"
            font.family: "{{ _font }}"
            font.pixelSize: 11
        }
    }

    // ── Clock timer ───────────────────────────────────────────────────────────

    Timer {
        interval: 30000
        running: true
        repeat: true
        onTriggered: {
            clockLabel.text = Qt.formatTime(new Date(), "HH:mm")
            dateLabel.text = Qt.formatDate(new Date(), "dddd, MMMM d")
        }
    }

    // ── Attribution ───────────────────────────────────────────────────────────

    Label {
        anchors.right: parent.right
        anchors.bottom: parent.bottom
        anchors.margins: 16
        text: "ricefy.org"
        color: "{{ config.colors.foreground }}"
        font.family: "{{ _font }}"
        font.pixelSize: 10
        opacity: 0.2
    }
}
