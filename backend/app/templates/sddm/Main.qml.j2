{%- set radius = [config.wm.rounding // 2, 12] | min -%}
{%- set h_anchors = {
    "left":   "anchors.left: parent.left\n        anchors.leftMargin: 80",
    "center": "anchors.horizontalCenter: parent.horizontalCenter",
    "right":  "anchors.right: parent.right\n        anchors.rightMargin: 80"
} -%}
{%- set v_anchors = {
    "top":    "anchors.top: parent.top\n        anchors.topMargin: 80",
    "center": "anchors.verticalCenter: parent.verticalCenter",
    "bottom": "anchors.bottom: parent.bottom\n        anchors.bottomMargin: 80"
} -%}
// Generated by Ricefy — {{ config.name }}

import QtQuick 2.0
import QtQuick.Controls 2.0
import QtQuick.Layouts 1.3
import SddmComponents 2.0

Rectangle {
    id: root

    TextConstants { id: textConstants }

    Connections {
        target: sddm
        onLoginFailed: {
            errorLabel.text = textConstants.loginFailed
            passwordInput.clear()
            passwordInput.forceActiveFocus()
        }
    }

    // ── Background ────────────────────────────────────────────────────────────

{% if config.lockscreen.background_image %}
    Image {
        anchors.fill: parent
        source: "{{ config.lockscreen.background_image }}"
        fillMode: Image.PreserveAspectCrop
        smooth: true
        asynchronous: true
    }
    Rectangle {
        anchors.fill: parent
        color: "{{ config.lockscreen.background_color }}"
        opacity: 0.4
    }
{% else %}
    color: "{{ config.lockscreen.background_color }}"
{% endif %}

    // ── Form container ────────────────────────────────────────────────────────

    Rectangle {
        id: formBox
        width: 360
        height: formColumn.implicitHeight + 48
        color: "{{ config.colors.surface }}"
        opacity: 0.95
        radius: {{ radius }}

        {{ h_anchors[config.lockscreen.layout] }}
        {{ v_anchors[config.lockscreen.layout_y] }}

        ColumnLayout {
            id: formColumn
            anchors.centerIn: parent
            width: 300
            spacing: 12

{% if config.lockscreen.show_logo %}
            // Logo / title
            Label {
                Layout.alignment: Qt.AlignHCenter
                text: "{{ config.name }}"
                color: "{{ config.colors.accent }}"
                font.family: "{{ config.lockscreen.font }}"
                font.pixelSize: 22
                font.bold: true
            }
{% endif %}

            // Username
            TextField {
                id: usernameInput
                Layout.fillWidth: true
                height: 40
                text: userModel.lastUser
                placeholderText: "Username"
                font.family: "{{ config.lockscreen.font }}"
                font.pixelSize: {{ config.font.size }}
                color: "{{ config.colors.foreground }}"
                background: Rectangle {
                    color: "{{ config.colors.border }}"
                    radius: {{ [radius - 2, 2] | max }}
                }
                Keys.onReturnPressed: passwordInput.forceActiveFocus()
            }

            // Password
            TextField {
                id: passwordInput
                Layout.fillWidth: true
                height: 40
                echoMode: TextInput.Password
                placeholderText: "Password"
                font.family: "{{ config.lockscreen.font }}"
                font.pixelSize: {{ config.font.size }}
                color: "{{ config.colors.foreground }}"
                background: Rectangle {
                    color: "{{ config.colors.border }}"
                    radius: {{ [radius - 2, 2] | max }}
                }
                Keys.onReturnPressed: sddm.login(usernameInput.text, passwordInput.text, sessionIndex)
            }

            // Login button
            Button {
                id: loginButton
                Layout.fillWidth: true
                height: 40
                text: "Sign in"
                onClicked: sddm.login(usernameInput.text, passwordInput.text, sessionIndex)

                background: Rectangle {
                    color: loginButton.pressed
                        ? Qt.darker("{{ config.colors.accent }}", 1.2)
                        : "{{ config.colors.accent }}"
                    radius: {{ [radius - 2, 2] | max }}
                }

                contentItem: Label {
                    text: loginButton.text
                    color: "{{ config.colors.background }}"
                    font.family: "{{ config.lockscreen.font }}"
                    font.pixelSize: {{ config.font.size }}
                    horizontalAlignment: Text.AlignHCenter
                    verticalAlignment: Text.AlignVCenter
                }
            }

            // Error label
            Label {
                id: errorLabel
                Layout.fillWidth: true
                horizontalAlignment: Text.AlignHCenter
                color: "#cc241d"
                font.family: "{{ config.lockscreen.font }}"
                font.pixelSize: {{ [config.font.size - 2, 8] | max }}
                wrapMode: Text.WordWrap
            }
        }
    }
}
