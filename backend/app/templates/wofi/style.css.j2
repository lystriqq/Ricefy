/* Generated by Ricefy — {{ config.name }} */
{%- set radius = [config.wm.rounding // 2, 8] | min %}

window {
    background-color:   {{ config.colors.background }};
    border-radius:      {{ radius }}px;
    border:             1px solid {{ config.colors.border }};
    font-family:        "{{ config.font.mono_family }}";
    font-size:          {{ config.font.size }}px;
}

#input {
    background-color:   {{ config.colors.surface }};
    color:              {{ config.colors.foreground }};
    border:             none;
    border-radius:      {{ radius }}px;
    padding:            8px 12px;
    margin:             8px 8px 4px 8px;
    caret-color:        {{ config.colors.accent }};
}

#input:focus {
    border:             1px solid {{ config.colors.accent }};
}

#inner-box {
    margin:             0px 8px 8px 8px;
}

#outer-box {
    margin:             0px;
}

#scroll {
    margin:             0px;
}

#entry {
    background-color:   transparent;
    color:              {{ config.colors.foreground }};
    padding:            8px 12px;
    border-radius:      {{ radius }}px;
}

#entry:selected {
    background-color:   {{ config.colors.accent }};
    color:              {{ config.colors.background }};
    border-radius:      {{ radius }}px;
}

#text {
    color:              {{ config.colors.foreground }};
}

#text:selected {
    color:              {{ config.colors.background }};
}

#img {
    margin-right:       8px;
}

#img:selected {
    background-color:   transparent;
}
