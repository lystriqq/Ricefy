# Generated by Ricefy — {{ config.name }}
{%- set bg_rgba  = "rgba(" ~ config.lockscreen.background_color[1:] ~ "ff)" -%}
{%- set fg_rgba  = "rgba(" ~ config.colors.foreground[1:]           ~ "ff)" -%}
{%- set acc_rgba = "rgba(" ~ config.colors.accent[1:]               ~ "ff)" -%}
{%- set sur_rgba = "rgba(" ~ config.colors.surface[1:]              ~ "ff)" -%}

general {
    disable_loading_bar = true
    hide_cursor         = true
    grace               = 0
    no_fade_in          = false
}

background {
    monitor =
{% if config.lockscreen.background_image %}
    path    = {{ config.lockscreen.background_image }}
{% else %}
    path    = screenshot
{% endif %}
    color   = {{ bg_rgba }}

{% if config.lockscreen.blur %}
    blur_size        = {{ config.lockscreen.blur_size }}
    blur_passes      = 2
    noise            = 0.0117
    contrast         = 0.8916
    brightness       = 0.8172
    vibrancy         = 0.1696
    vibrancy_darkness = 0.0
{% else %}
    blur_passes      = 0
{% endif %}
}

{% if config.lockscreen.clock %}
label {
    monitor =
    text        = cmd[update:1000] echo "$(date +'{{ config.lockscreen.date_format }}')"
    color       = {{ fg_rgba }}
    font_size   = 56
    font_family = {{ config.font.heading_family }} Bold
    position    = 0, 80
    halign      = {{ config.lockscreen.layout }}
    valign      = {{ config.lockscreen.layout_y }}
}
{% endif %}

input-field {
    monitor =
    size             = 300, 50
    outline_thickness = 2
    dots_size        = 0.33
    dots_spacing     = 0.15
    dots_center      = true
    outer_color      = {{ acc_rgba }}
    inner_color      = {{ sur_rgba }}
    font_color       = {{ fg_rgba }}
    fade_on_empty    = true
    placeholder_text = <i>Enter password...</i>
    hide_input       = false
    rounding         = {{ config.wm.rounding }}
    check_color      = {{ acc_rgba }}
    fail_color       = rgba(cc241dff)
    fail_text        = <i>Incorrect password</i>
    position         = 0, -80
    halign           = {{ config.lockscreen.layout }}
    valign           = center
}
